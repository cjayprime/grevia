              </td>
              <td class="f06ca7">
                <div class="Normal_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="font-size:13px; min-height:13px; margin:0px"></div>
              </td>
            </tr>
          </table>
          <div class="BasicnumberredN_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="text-indent:0; display:flex; margin-left:0px">
            <span class="numbering-583-level-0" style="font-weight:normal; font-style:normal" dir="ltr" id="id-358">
              <a href="#id-358">178.</a>
            </span>
            <span style="display:contents" dir="ltr">The following table shows how information on</span>
            <span style="font-weight:bold; font-style:italic; display:contents" dir="ltr">employees</span>
            <span style="display:contents" dir="ltr">may be presented by gender.</span>
          </div>
          <table class="TableGrid" style="width:100%; border-collapse:collapse; margin:0px auto 0px 0px; " dir="ltr">
            <tr class="fdd366">
              <td class="d6f8fc6">
                <div class="Normal_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="margin-bottom:0px">
                  <span style="font-size:13px; min-height:13px; font-weight:bold" dir="ltr">Gender</span>
                </div>
              </td>
              <td class="d1f1dc8">
                <div class="Normal_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="margin-bottom:0px">
                  <span style="font-size:13px; min-height:13px; font-weight:bold" dir="ltr">Number of employees (headcount or full-time equivalents)</span>
                </div>
              </td>
            </tr>
            <tr class="d71274c">
              <td class="d615ce3">
                <div class="Normal_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="margin-top:0px; margin-bottom:0px">
                  <span style="font-size:13px; min-height:13px" dir="ltr">Male</span>
                </div>
              </td>
              <td class="d7bd57">
                <div class="Normal_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="font-size:13px; min-height:13px; margin:0px"></div>
              </td>
            </tr>
            <tr class="d71274c">
              <td class="d615ce3">
                <div class="Normal_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="margin-top:0px; margin-bottom:0px">
                  <span style="font-size:13px; min-height:13px" dir="ltr">Female</span>
                </div>
              </td>
              <td class="d7bd57">
                <div class="Normal_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="font-size:13px; min-height:13px; margin:0px"></div>
              </td>
            </tr>
            <tr class="d71274c">
              <td class="d615ce3">
                <div class="Normal_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="margin-top:0px; margin-bottom:0px">
                  <span style="font-size:13px; min-height:13px" dir="ltr">Other</span>
                </div>
              </td>
              <td class="d7bd57">
                <div class="Normal_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight_MarginsClippedToRowHeight" style="font-size:13px; min-height:13px; margin:0px"></div>
              </td>
            </tr>
            <tr class="d71274c">
              <td class="d615ce3">
